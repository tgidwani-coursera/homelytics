# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=homelytics
DB_USER=homelytics
DB_PASSWORD=change_me

# Rajasthan RERA 2.0 endpoints
# RERA_BASE_URL is the public site (used as Referer + to resolve document URLs).
# RERA_API_URL is the JSON API backing the SPA.
RERA_BASE_URL=https://rera.rajasthan.gov.in
RERA_API_URL=https://reraapi.rajasthan.gov.in
# Legacy host serving the full ViewProjectWebsite record (allottees, apartments,
# documents, common areas, promoter history).
RERA_LEGACY_URL=https://reraapp.rajasthan.gov.in

# Static client-side API key the portal ships to every browser. If the portal
# rotates it, capture the new value from the browser network tab (x-api-key).
RERA_API_KEY=MySuperSecretApiKey_123

# Scraper rate limiting (seconds between API calls)
RATE_LIMIT_MIN=2.0
RATE_LIMIT_MAX=3.0
